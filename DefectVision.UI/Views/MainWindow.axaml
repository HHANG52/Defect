<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:DefectVision.UI.Views"
        xmlns:vm="using:DefectVision.UI.ViewModels"
        x:Class="DefectVision.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="DefectVision"
        Width="1400" Height="900"
        MinWidth="1024" MinHeight="700"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Top toolbar -->
        <Border Grid.Row="0" Background="#1565C0" Padding="12,8">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="DefectVision" FontSize="20" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center" />
                    <TextBlock Text="|" Foreground="#80FFFFFF" VerticalAlignment="Center" Margin="8,0" />
                    <TextBlock Text="{Binding ProjectName}" Foreground="#E0E0E0"
                               VerticalAlignment="Center" FontSize="14" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <Button Command="{Binding OpenProjectCommand}"
                            Background="Transparent" Foreground="White"
                            x:Name="BtnOpenProject" />
                    <Button Command="{Binding NewProjectCommand}"
                            Background="Transparent" Foreground="White"
                            x:Name="BtnNewProject" />
                    <Button Command="{Binding ConfigurePythonCommand}"
                            Background="Transparent" Foreground="White"
                            x:Name="BtnPythonSetup" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tab pages -->
        <TabControl Grid.Row="1" TabStripPlacement="Left" Padding="0">
            <TabItem x:Name="TabAnnotation" FontSize="14" MinHeight="50">
                <views:AnnotationView DataContext="{Binding AnnotationVM}" />
            </TabItem>
            <TabItem x:Name="TabTraining" FontSize="14" MinHeight="50">
                <views:TrainingView DataContext="{Binding TrainingVM}" />
            </TabItem>
            <TabItem x:Name="TabModel" FontSize="14" MinHeight="50">
                <views:ModelManagerView DataContext="{Binding ModelManagerVM}" />
            </TabItem>
            <TabItem x:Name="TabDetection" FontSize="14" MinHeight="50">
                <views:DetectionView DataContext="{Binding DetectionVM}" />
            </TabItem>
        </TabControl>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#37474F" Padding="12,4">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Text="{Binding StatusText}" Foreground="White" FontSize="12"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0">
                    <TextBlock x:Name="LblModel" Foreground="#AAA" FontSize="11"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ActiveModelName}" Foreground="#4FC3F7"
                               FontSize="11" VerticalAlignment="Center" Margin="4,0,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock x:Name="LblGpu" Foreground="#AAA" FontSize="11"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding GpuInfo}" Foreground="#81C784"
                               FontSize="11" VerticalAlignment="Center" Margin="4,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>