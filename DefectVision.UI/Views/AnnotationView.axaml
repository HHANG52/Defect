<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>
        
        <!-- Left Panel -->
        <StackPanel Grid.Column="0">
            <Button Command="{Binding ImportImagesCommand}" Content="Import Images"/>  
            <ItemsControl ItemsSource="{Binding ImageList}">
                <Image Source="{Binding SelectedImage}"/>
            </ItemsControl>
            <TextBlock Text="Labeled Count: {Binding LabeledCount}"/>
            <TextBlock Text="Total Count: {Binding TotalCount}"/>
            <ProgressBar Value="{Binding LabelProgress}"/>
            <ComboBox ItemsSource="{Binding ClassList}" SelectedItem="{Binding SelectedClassItem}"/>
            <Button Command="{Binding AddClassCommand}" Content="Add Class"/>  
        </StackPanel>
        
        <!-- Center Canvas -->
        <Canvas Grid.Column="1" Background="White"
                PointerPressed="Canvas_PointerPressed"
                PointerMoved="Canvas_PointerMoved"
                PointerReleased="Canvas_PointerReleased"
                PointerWheelChanged="Canvas_PointerWheelChanged">
            <ToolBar>
                <Button Command="{Binding IsRectTool}" Content="Rectangle"/>
                <Button Command="{Binding IsPolygonTool}" Content="Polygon"/>
                <Button Command="{Binding IsPanTool}" Content="Pan"/>
                <Button Command="{Binding UndoCommand}" Content="Undo"/>
                <Button Command="{Binding RedoCommand}" Content="Redo"/>
                <Button Command="{Binding DeleteSelectedCommand}" Content="Delete"/>
            </ToolBar>
            <TextBlock Text="Zoom: {Binding ZoomPercentText}"/>
            <ItemsControl ItemsSource="{Binding CurrentAnnotations}"/>
        </Canvas>
        <StatusBar Grid.Column="1" Content="{Binding StatusMessage}"/>
        
        <!-- Right Panel -->
        <StackPanel Grid.Column="2">
            <ItemsControl ItemsSource="{Binding CurrentAnnotations}"/>
            <Button Command="{Binding MarkCompletedCommand}" Content="Mark Completed"/>
            <Button Command="{Binding SaveAnnotationCommand}" Content="Save Annotation"/>
            <Button Command="{Binding ExportDatasetCommand}" Content="Export Dataset"/>
            <Button Command="{Binding ImportYoloCommand}" Content="Import Yolo"/>
            <Button Command="{Binding DeleteAnnotationCommand}" Content="Delete Annotation"/>
        </StackPanel>
    </Grid>
</UserControl>